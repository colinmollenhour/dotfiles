{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(npm ci)",
      "Bash(npm run *)",
      "Bash(pnpm install)",
      "Bash(pnpm install:*)",
      "Bash(yarn install)",
      "Bash(pip install:*)",
      "Bash(uv pip install:*)",
      "Bash(cargo build:*)",
      "Bash(cargo test:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git push:*)",
      "Bash(cup *)",
      "Bash(glab *)",
      "Bash(gh *)",
      "Read",
      "Edit",
      "Write",
      "MultiEdit",
      "Glob",
      "Grep",
      "LS",
      "WebSearch",
      "TodoWrite",
      "Skill(colin:commit-and-push)",
      "WebFetch(domain:proxy.golang.org)",
      "WebFetch(domain:0.0.0.0)",
      "WebFetch(domain:api.github.com)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:api.osv.dev)",
      "WebFetch(domain:registry.npmjs.org)",
      "WebFetch(domain:gitlab.bss-llc.com)"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.development)",
      "Read(.env.production)",
      "Read(.env.test)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "network": {
      "allowedDomains": [
        "registry.npmjs.org",
        "*.npmjs.org",
        "registry.yarnpkg.com",
        "*.yarnpkg.com",
        "pypi.org",
        "files.pythonhosted.org",
        "*.pythonhosted.org",
        "github.com",
        "*.github.com",
        "raw.githubusercontent.com",
        "objects.githubusercontent.com",
        "api.anthropic.com",
        "crates.io",
        "static.crates.io",
        "index.crates.io",
        "registry.hub.docker.com",
        "deb.debian.org",
        "archive.ubuntu.com",
        "security.ubuntu.com",
        "proxy.golang.org",
        "api.osv.dev",
        "gitlab.bss-llc.com"
      ]
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "agentPushNotifEnabled": true
}
